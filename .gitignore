# Python build artifacts.
# IMPORTANT: directories below are anchored with leading `/` so they only
# match at the repo root. Without the anchor, `lib/` would silently exclude
# `dashboard/lib/` and `extension/lib/` — same trap as the M0 `SYNAPSE/`
# collision. Always anchor generic dir names.
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
.eggs/
/lib/
/lib64/
/parts/
/sdist/
/var/
/wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.uv/

# uv
.python-version

# Environment / secrets
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.ruff_cache/
.pyre/

# Logs
*.log
logs/

# Synapse runtime data — never commit captured user data.
# IMPORTANT: do NOT add `SYNAPSE/` here. On case-insensitive filesystems
# (Windows, default macOS) it would collide with the `synapse/` Python
# package and silently exclude all source code from commits.
/vault/
/synapse_vault/
*.db
*.db-journal
*.sqlite
*.sqlite3
chroma/
.chroma/
.synapse/

# Dashboard (Next.js)
dashboard/node_modules/
dashboard/.next/
dashboard/out/
dashboard/.vercel/

# Browser extension
extension/dist/
extension/*.zip
