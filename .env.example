# Synapse — environment configuration

# ── Core ───────────────────────────────────────────────────────────────
# Master encryption key for credentials. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SYNAPSE_SECRET_KEY=

# Absolute path to the Obsidian vault root. `synapse init` creates this.
# NOTE: Do NOT name this `SYNAPSE` if the repo also contains a `synapse/`
# Python package — Windows is case-insensitive and they will collide.
SYNAPSE_VAULT_PATH=

# Gateway bind host / port
SYNAPSE_GATEWAY_HOST=
SYNAPSE_GATEWAY_PORT=

# Log level: DEBUG | INFO | WARNING | ERROR
SYNAPSE_LOG_LEVEL=

# ── LLM (needed from Milestone 1) ──────────────────────────────────────
# Tiered: Sonnet for Librarian/Scout/Guardian, Opus for Synthesizer/Critic/Strategist.
ANTHROPIC_API_KEY=
# OpenAI is NOT used (voice → local faster-whisper). Leave blank.
# OPENAI_API_KEY=

# ── Capture ────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Optional: restrict the bot to a single Telegram user id (your numeric id)
TELEGRAM_ALLOWED_USER_ID=

# Shared secret for /ingest/email webhook (HMAC-SHA256 of body, hex)
SYNAPSE_EMAIL_WEBHOOK_SECRET=

# API key for browser extension to call /ingest/browser
SYNAPSE_BROWSER_API_KEY=

# ── Integrations (populated via OAuth flow in Milestone 4+) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Vision / OCR (Milestone 5) ─────────────────────────────────────────
# Google Cloud Vision is NOT used (OCR → Tesseract local + Claude vision). Leave blank.
# GOOGLE_CLOUD_VISION_API_KEY=

# ── Dashboard (Milestone 5) ────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=